# Database settings
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/dbname

# JWT Security
SECRET_KEY=your_jwt_secret_key_here

GROQ_API_KEY=your_api_key
TAVILY_API_KEY=your_tavily_api_key
GEMINI_API_KEY=your_gemini_api_key
YOUTUBE_API_KEY=your_youtube_data_api_key
APIFY_API_TOKEN=your_apify_api_token
APIFY_ACTOR_ID=your_shared_social_actor_id
# Optional platform-specific overrides:
APIFY_INSTAGRAM_ACTOR_ID=apify/instagram-scraper
APIFY_TIKTOK_ACTOR_ID=clockworks/free-tiktok-scraper

# Tunneling — set this to expose the app publicly via ngrok
# Get a free token at https://dashboard.ngrok.com/get-started/your-authtoken
# Then run: docker compose --profile tunnel up
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# ── AI-usage stack (branch sakib/ai-score-max) ───────────────────────────────
# Admin AI Assistant: a LangChain agent (Groq) that calls the Cohesiq MCP server.
# Reuses GROQ_API_KEY above. Disable the feature entirely with ASSISTANT_ENABLED=false.
ASSISTANT_ENABLED=true
ASSISTANT_MODEL=llama-3.1-8b-instant
# URL of the Cohesiq MCP server (streamable HTTP). Docker default shown.
# Start the server with: docker compose --profile ai up -d mcp
MCP_HTTP_URL=http://mcp:8001/mcp

# Optional local LLM (Ollama / Hermes). Leave OLLAMA_BASE_URL empty to stay on Groq.
# Enable with: docker compose --profile local-llm up -d ollama
#   then:      docker compose exec ollama ollama pull hermes3
OLLAMA_BASE_URL=
OLLAMA_MODEL=hermes3

# Grafana admin login (profile `ai` / `observability`).
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=cohesiq

# n8n basic auth (profile `automation`).
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=cohesiq

# Cron secret — shared between backend and n8n workflows.
# Generate with: openssl rand -hex 32
# Set the same value as CRON_SECRET in n8n's environment variables.
CRON_SECRET=replace_with_a_long_random_secret

# n8n webhook base URL (used by the backend to fire the campaign-launch trigger).
# Set to the n8n instance's public webhook base, e.g. http://n8n:5678/webhook
N8N_WEBHOOK_BASE_URL=http://n8n:5678/webhook
