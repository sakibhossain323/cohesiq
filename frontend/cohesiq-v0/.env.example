NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# ── API URL Configuration ────────────────────────────────────────────────────
# BACKEND_API_URL: Read ONLY by the Next.js SERVER (Server Components, Server
# Actions, Route Handlers). Points to the FastAPI container via Docker's
# internal network. This value is IDENTICAL across all environments — do not
# change it unless the Docker service name in docker-compose.yml changes.
BACKEND_API_URL=http://backend:8000

# NEXT_PUBLIC_API_URL: Read by the END-USER'S BROWSER (client components).
# Must be a publicly reachable URL. Set this correctly for each environment:
#   - Local dev: http://localhost:8000
#   - Staging:   http://<staging-server-ip>:8000
# NEVER use http://localhost:8000 in staging — it points to the local development environment.
NEXT_PUBLIC_API_URL=http://localhost:8000

GROQ_API_KEY=your_api_key
TAVILY_API_KEY=your_tavily_api_key
GEMINI_API_KEY=your_gemini_api_key

# NEXT_ALLOWED_DEV_ORIGINS: Comma-separated list of extra hosts allowed to connect
# to the Next.js dev server WebSocket (HMR). Add your EC2 IP here for remote dev access.
# Example: NEXT_ALLOWED_DEV_ORIGINS=3.224.147.223
# ngrok wildcard domains are already included by default in next.config.mjs.
NEXT_ALLOWED_DEV_ORIGINS=

# ── Tunneling (ngrok) ─────────────────────────────────────────────────────────
# Required to start the ngrok service: docker compose --profile tunnel up
# Get a free token at https://dashboard.ngrok.com/get-started/your-authtoken
# Once running, view the public URL at http://localhost:4040 or:
#   docker compose logs ngrok | grep url
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# YouTube OAuth configuration
YOUTUBE_CLIENT_ID=your_youtube_oauth_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_youtube_oauth_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback

# TikTok OAuth configuration
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/tiktok/callback
